{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HTTPDSL",
  "scopeName": "source.httpdsl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#help-block" },
    { "include": "#route-definition" },
    { "include": "#group-definition" },
    { "include": "#server-block" },
    { "include": "#error-handler" },
    { "include": "#every-block" },
    { "include": "#fn-definition" },
    { "include": "#block-keywords" },
    { "include": "#expressions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.httpdsl",
          "match": "//.*$"
        }
      ]
    },

    "help-block": {
      "begin": "\\b(help)\\s*(`)",
      "end": "`",
      "beginCaptures": {
        "1": { "name": "keyword.control.help.httpdsl" },
        "2": { "name": "string.quoted.template.httpdsl punctuation.definition.string.begin.httpdsl" }
      },
      "endCaptures": {
        "0": { "name": "string.quoted.template.httpdsl punctuation.definition.string.end.httpdsl" }
      },
      "contentName": "string.quoted.template.httpdsl"
    },

    "route-definition": {
      "match": "\\b(route)\\s+(GET|POST|PUT|PATCH|DELETE|OPTIONS|HEAD|SSE)\\b",
      "captures": {
        "1": { "name": "keyword.control.route.httpdsl" },
        "2": { "name": "constant.language.http-method.httpdsl" }
      }
    },

    "group-definition": {
      "match": "\\b(group)\\s+",
      "captures": {
        "1": { "name": "keyword.control.group.httpdsl" }
      }
    },

    "server-block": {
      "match": "\\b(server)(?=\\s*\\{)",
      "captures": {
        "1": { "name": "keyword.control.server.httpdsl" }
      }
    },

    "error-handler": {
      "match": "\\b(error)\\s+(\\d+)\\s*(?=\\{)",
      "captures": {
        "1": { "name": "keyword.control.error.httpdsl" },
        "2": { "name": "constant.numeric.integer.httpdsl" }
      }
    },

    "every-block": {
      "match": "\\b(every)\\s+(?:(\\d+\\s*[smh])|(\"[^\"]*\"))\\s*(?=\\{)",
      "captures": {
        "1": { "name": "keyword.control.every.httpdsl" },
        "2": { "name": "constant.numeric.duration.httpdsl" },
        "3": { "name": "string.quoted.double.httpdsl" }
      }
    },

    "fn-definition": {
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.control.fn.httpdsl" },
        "2": { "name": "entity.name.function.httpdsl" }
      }
    },

    "block-keywords": {
      "patterns": [
        {
          "match": "\\b(init|shutdown)(?=\\s*\\{)",
          "name": "keyword.control.httpdsl"
        },
        {
          "match": "\\b(before|after)(?=\\s*\\{)",
          "name": "keyword.control.httpdsl"
        }
      ]
    },

    "expressions": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#template-strings" },
        { "include": "#numbers" },
        { "include": "#constants" },
        { "include": "#keywords" },
        { "include": "#special-variables" },
        { "include": "#db-access" },
        { "include": "#store-access" },
        { "include": "#jwt-access" },
        { "include": "#file-access" },
        { "include": "#stream-access" },
        { "include": "#builtin-functions" },
        { "include": "#function-call" },
        { "include": "#operators" },
        { "include": "#punctuation" }
      ]
    },

    "strings": {
      "name": "string.quoted.double.httpdsl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.httpdsl",
          "match": "\\\\(?:[\\\\\"nrt0])"
        }
      ]
    },

    "template-strings": {
      "name": "string.quoted.template.httpdsl",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "constant.character.escape.httpdsl",
          "match": "\\\\(?:[\\\\`nrt])"
        },
        {
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.httpdsl" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.httpdsl" }
          },
          "contentName": "meta.interpolation.httpdsl",
          "patterns": [
            { "include": "#expressions" }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.httpdsl",
          "match": "(?<![a-zA-Z_])\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.duration.httpdsl",
          "match": "\\b\\d+[smhd]\\b"
        },
        {
          "name": "constant.numeric.integer.httpdsl",
          "match": "(?<![a-zA-Z_\\.])\\d+\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.httpdsl",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.httpdsl",
          "match": "\\bfalse\\b"
        },
        {
          "name": "constant.language.null.httpdsl",
          "match": "\\bnull\\b"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.httpdsl",
          "match": "\\b(?:route|fn|return|if|else|while|each|in|break|continue|try|catch|throw|async|await|switch|case|default)\\b"
        }
      ]
    },

    "special-variables": {
      "patterns": [
        {
          "match": "\\b(request)\\s*\\.\\s*(data|headers|method|path|query|params|cookies|ip|session|bearer|basic)\\b",
          "captures": {
            "1": { "name": "variable.language.request.httpdsl" },
            "2": { "name": "variable.other.property.httpdsl" }
          }
        },
        {
          "match": "\\b(response)\\s*\\.\\s*(body|status|type|headers|cookies)\\b",
          "captures": {
            "1": { "name": "variable.language.response.httpdsl" },
            "2": { "name": "variable.other.property.httpdsl" }
          }
        },
        {
          "name": "variable.language.httpdsl",
          "match": "\\b(?:request|response|args)\\b"
        }
      ]
    },

    "builtin-functions": {
      "patterns": [
        {
          "match": "\\b(len|type|int|float|str|bool|print|log|log_info|log_warn|log_error|keys|values|merge|hash|append|push|split|join|trim|lower|upper|capitalize|replace|contains|starts_with|ends_with|index_of|repeat|pad_left|pad_right|truncate|regex_match|regex_replace|slice|reverse|sort|sort_by|filter|map|reduce|find|some|every|count|flat|unique|chunk|pluck|group_by|sum|range|abs|ceil|floor|round|min|max|clamp|rand|now|now_ms|date|date_format|date_parse|strtotime|sleep|uuid|cuid2|hash_password|verify_password|hmac_hash|env|fetch|redirect|render|broadcast|validate|is_email|is_url|is_uuid|is_numeric|url_encode|url_decode|base64_encode|base64_decode|exec|server_stats|set_session_store|csrf_token|csrf_field)\\s*\\(",
          "captures": {
            "1": { "name": "support.function.builtin.httpdsl" }
          }
        }
      ]
    },

    "db-access": {
      "patterns": [
        {
          "match": "\\b(db)\\s*\\.\\s*(open)\\s*\\(",
          "captures": {
            "1": { "name": "variable.language.db.httpdsl" },
            "2": { "name": "support.function.db.httpdsl" }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\.\\s*(exec|query|query_one|query_value|find|find_one|insert|insert_many|update|delete|count|close)\\s*\\(",
          "captures": {
            "2": { "name": "support.function.db.httpdsl" }
          }
        }
      ]
    },

    "store-access": {
      "patterns": [
        {
          "match": "\\b(store)\\s*\\.\\s*(get|set|delete|has|all|incr|sync)\\s*\\(",
          "captures": {
            "1": { "name": "variable.language.store.httpdsl" },
            "2": { "name": "support.function.store.httpdsl" }
          }
        }
      ]
    },

    "jwt-access": {
      "patterns": [
        {
          "match": "\\b(jwt)\\s*\\.\\s*(sign|verify)\\s*\\(",
          "captures": {
            "1": { "name": "variable.language.jwt.httpdsl" },
            "2": { "name": "support.function.jwt.httpdsl" }
          }
        }
      ]
    },

    "file-access": {
      "patterns": [
        {
          "match": "\\b(file)\\s*\\.\\s*(open|read|write|append|read_json|write_json|exists|delete|list|mkdir|chmod)\\s*\\(",
          "captures": {
            "1": { "name": "variable.language.file.httpdsl" },
            "2": { "name": "support.function.file.httpdsl" }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\.\\s*(read|write|append|lines|json|write_json|exists|size|delete|path)\\s*\\(",
          "captures": {
            "2": { "name": "support.function.file.httpdsl" }
          }
        }
      ]
    },

    "stream-access": {
      "patterns": [
        {
          "match": "\\b(stream)\\s*\\.\\s*(send|join|leave|set|get|close|channels)\\s*\\(",
          "captures": {
            "1": { "name": "variable.language.stream.httpdsl" },
            "2": { "name": "support.function.stream.httpdsl" }
          }
        },
        {
          "match": "\\b(sse)\\s*\\.\\s*(find|find_by|channel|broadcast|count|channels)\\s*\\(",
          "captures": {
            "1": { "name": "variable.language.sse.httpdsl" },
            "2": { "name": "support.function.stream.httpdsl" }
          }
        }
      ]
    },

    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.httpdsl" }
          }
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.httpdsl",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.httpdsl",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.httpdsl",
          "match": "\\+=|-=|="
        },
        {
          "name": "keyword.operator.arithmetic.httpdsl",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.nullish.httpdsl",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.ternary.httpdsl",
          "match": "\\?"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.httpdsl",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.httpdsl",
          "match": ":"
        }
      ]
    }
  }
}
