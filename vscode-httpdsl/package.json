{
  "name": "httpdsl",
  "displayName": "HTTPDSL",
  "description": "Syntax highlighting for the HTTPDSL language",
  "version": "0.1.0",
  "publisher": "pixelkarma",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "httpdsl",
        "aliases": [
          "HTTPDSL",
          "httpdsl"
        ],
        "extensions": [
          ".httpdsl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "httpdsl",
        "scopeName": "source.httpdsl",
        "path": "./syntaxes/httpdsl.tmLanguage.json"
      }
    ]
  }
}
