{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://httpdsl.dev/spec/schema/builtins.schema.json",
  "title": "HTTPDSL Builtins Spec",
  "type": "object",
  "required": ["meta", "groups"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "meta": {
      "type": "object",
      "required": ["name", "specVersion", "updatedAt"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "specVersion": { "type": "string", "minLength": 1 },
        "updatedAt": { "type": "string", "format": "date" },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/group" }
    }
  },
  "$defs": {
    "group": {
      "type": "object",
      "required": ["id", "name", "kind", "items"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["functions", "namespace", "methods"] },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/item" }
        }
      }
    },
    "item": {
      "type": "object",
      "required": ["name", "syntax", "summary"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "syntax": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "contexts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "availability": { "type": "string" }
      }
    }
  }
}
