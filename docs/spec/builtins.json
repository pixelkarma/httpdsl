{
  "$schema": "./schema/builtins.schema.json",
  "meta": {
    "name": "HTTPDSL Builtins",
    "specVersion": "1.0.0",
    "updatedAt": "2026-03-10",
    "notes": [
      "Builtins are listed by callable surface (functions, namespaces, and method-like APIs).",
      "Availability can depend on runtime context (session enabled, SSE route, DB driver configured)."
    ]
  },
  "groups": [
    {
      "id": "core-functions",
      "name": "Core Functions",
      "kind": "functions",
      "items": [
        { "name": "print", "syntax": "print(...values)", "summary": "Prints values to stdout/log output." },
        { "name": "log", "syntax": "log(...values)", "summary": "Structured log message." },
        { "name": "log_info", "syntax": "log_info(...values)", "summary": "Info-level log." },
        { "name": "log_warn", "syntax": "log_warn(...values)", "summary": "Warn-level log." },
        { "name": "log_error", "syntax": "log_error(...values)", "summary": "Error-level log." },
        { "name": "env", "syntax": "env(name)", "summary": "Reads environment variable." },
        { "name": "sleep", "syntax": "sleep(ms)", "summary": "Sleeps current flow for milliseconds." },
        { "name": "fetch", "syntax": "fetch(url[, options])", "summary": "HTTP client request." },
        { "name": "exec", "syntax": "exec(command[, options])", "summary": "Executes shell command." },
        { "name": "now", "syntax": "now()", "summary": "Unix timestamp seconds." },
        { "name": "now_ms", "syntax": "now_ms()", "summary": "Unix timestamp milliseconds." },
        { "name": "server_stats", "syntax": "server_stats()", "summary": "Returns runtime server metrics." },
        { "name": "await", "syntax": "await(task)", "summary": "Waits for async task result." },
        { "name": "race", "syntax": "race(tasks)", "summary": "Resolves first task completion." },
        { "name": "render", "syntax": "render(template[, data])", "summary": "Renders configured template." },
        { "name": "redirect", "syntax": "redirect(url[, status])", "summary": "Returns redirect response payload." },
        { "name": "broadcast", "syntax": "broadcast(data)", "summary": "Broadcasts to SSE clients.", "availability": "Only meaningful when SSE is enabled." },
        { "name": "set_session_store", "syntax": "set_session_store(adapter)", "summary": "Sets backing session store." },
        { "name": "csrf_token", "syntax": "csrf_token()", "summary": "Gets CSRF token for active session.", "availability": "Requires session+CSRF configuration." },
        { "name": "csrf_field", "syntax": "csrf_field()", "summary": "Gets CSRF hidden form field markup.", "availability": "Requires session+CSRF configuration." }
      ]
    },
