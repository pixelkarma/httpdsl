// ──────────────────────────────────────────────
//  User Registration Validator
//  POST /register with name, email, and US address
// ──────────────────────────────────────────────

server {
    port 8000
}

// ── Valid US state codes ─────────────────────

fn valid_states() {
    return [
        "AL", "AK", "AZ", "AR", "CA", "CO", "CT", "DE", "FL", "GA",
        "HI", "ID", "IL", "IN", "IA", "KS", "KY", "LA", "ME", "MD",
        "MA", "MI", "MN", "MS", "MO", "MT", "NE", "NV", "NH", "NJ",
        "NM", "NY", "NC", "ND", "OH", "OK", "OR", "PA", "RI", "SC",
        "SD", "TN", "TX", "UT", "VT", "VA", "WA", "WV", "WI", "WY",
        "DC", "PR", "VI", "GU", "AS", "MP"
    ]
}

fn is_valid_state(code) {
    states = valid_states()
    code = upper(trim(code))
    each state, i in states {
        if state == code {
            return true
        }
    }
    return false
}

// ── Validation helpers ───────────────────────

fn is_blank(val) {
    if type(val) != "string" {
        return true
    }
    return len(trim(val)) == 0
}

fn validate_name(name) {
    errors = []

    if is_blank(name) {
        return append(errors, "name is required")
    }

    name = trim(name)

    if len(name) < 2 {
        errors = append(errors, "name must be at least 2 characters")
    }

    if len(name) > 100 {
        errors = append(errors, "name must be 100 characters or less")
    }

    // Must contain a space (first + last)
    if !contains(name, " ") {
        errors = append(errors, "please provide first and last name")
    }

    return errors
}

fn validate_email(email) {
    errors = []

    if is_blank(email) {
        return append(errors, "email is required")
    }

    email = trim(lower(email))

    if !contains(email, "@") {
        errors = append(errors, "email must contain @")
        return errors
    }

    parts = split(email, "@")
    if len(parts) != 2 {
        errors = append(errors, "email must have exactly one @")
        return errors
    }

    local = parts[0]
    domain = parts[1]

    if len(local) == 0 {
        errors = append(errors, "email local part cannot be empty")
    }

    if !contains(domain, ".") {
        errors = append(errors, "email domain must contain a dot")
    }

    if len(domain) < 3 {
        errors = append(errors, "email domain is too short")
    }

    return errors
}

fn validate_zip(zip) {
    if is_blank(zip) {
        return "zip code is required"
    }
    zip = trim(zip)

    // Accept 5-digit or 9-digit (with dash)
    if len(zip) == 5 {
        return null
    }
    if len(zip) == 10 {
        if zip[5] == "-" {
            return null
        }
    }
    return "zip must be 5 digits (12345) or ZIP+4 (12345-6789)"
}

fn validate_address(address) {
    errors = []

    if type(address) != "object" {
        return append(errors, "address is required and must be an object")
    }

    // Street
    if is_blank(address["street"]) {
        errors = append(errors, "street is required")
    } else {
        if len(trim(address["street"])) < 5 {
            errors = append(errors, "street must be at least 5 characters")
        }
    }

    // City
    if is_blank(address["city"]) {
        errors = append(errors, "city is required")
    } else {
        if len(trim(address["city"])) < 2 {
            errors = append(errors, "city must be at least 2 characters")
        }
    }

    // State
    if is_blank(address["state"]) {
        errors = append(errors, "state is required")
    } else {
        if !is_valid_state(address["state"]) {
            errors = append(errors, "state must be a valid 2-letter US state code")
        }
    }

    // Zip
    zip_err = validate_zip(address["zip"])
    if zip_err != null {
        errors = append(errors, zip_err)
    }

    return errors
}

// ── Main registration endpoint ───────────────

route POST "register" {
    body = json.parse(request.body)

    if body == null {
        return json 400 {
            "success": false,
            "error": "invalid JSON body"
        }
    }

    all_errors = {}

    // Validate name
    name_errors = validate_name(body["name"])
    if len(name_errors) > 0 {
        all_errors["name"] = name_errors
    }

    // Validate email
    email_errors = validate_email(body["email"])
    if len(email_errors) > 0 {
        all_errors["email"] = email_errors
    }

    // Validate address
    address_errors = validate_address(body["address"])
    if len(address_errors) > 0 {
        all_errors["address"] = address_errors
    }

    // Return result
    if len(all_errors) > 0 {
        return json 422 {
            "success": false,
            "errors": all_errors
        }
    }

    return json 201 {
        "success": true,
        "message": "registration accepted",
        "user": {
            "name": trim(body["name"]),
            "email": trim(lower(body["email"])),
            "address": {
                "street": trim(body["address"]["street"]),
                "city": trim(body["address"]["city"]),
                "state": upper(trim(body["address"]["state"])),
                "zip": trim(body["address"]["zip"])
            }
        }
    }
}

// ── Info endpoint ────────────────────────────

route GET "" {
    return json {
        "service": "user registration validator",
        "usage": "POST /register",
        "required_fields": {
            "name": "full name (first and last)",
            "email": "valid email address",
            "address": {
                "street": "street address",
                "city": "city name",
                "state": "2-letter US state code",
                "zip": "5-digit or ZIP+4 format"
            }
        }
    }
}
