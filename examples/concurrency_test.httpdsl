// Concurrency & thread-safe store test
server {
    port 8000
}

// Thread-safe counter using store
route POST "count/:name" {
    count = store.incr("counter:" + params.name)
    return json {
        "name": params.name,
        "count": count
    }
}

route GET "count/:name" {
    count = store.get("counter:" + params.name, 0)
    return json {
        "name": params.name,
        "count": count
    }
}

// Store CRUD
route POST "store/:key" {
    body = json.parse(request.body)
    store.set(params.key, body)
    return json 201 { "stored": params.key }
}

route GET "store/:key" {
    val = store.get(params.key)
    if val == null {
        return json 404 { "error": "not found" }
    }
    return json { "key": params.key, "value": val }
}

route DELETE "store/:key" {
    store.delete(params.key)
    return json { "deleted": params.key }
}

route GET "store" {
    return json { "data": store.all() }
}

// Response headers & cookies
route GET "with-headers" {
    header("X-Custom-Header", "httpdsl")
    header("X-Request-Id", uuid())
    cookie("session", uuid(), { "httpOnly": true, "maxAge": 3600, "sameSite": "lax" })
    return json { "message": "check the response headers" }
}

// Redirect
route GET "old-path" {
    return redirect("/new-path", 301)
}

route GET "new-path" {
    return json { "message": "you were redirected here" }
}

// Slow endpoint to test concurrent requests
route GET "slow" {
    sleep(100)
    store.incr("slow_hits")
    return json { "hits": store.get("slow_hits") }
}

route GET "" {
    return json { "test": "concurrency", "endpoints": [
        "POST /count/:name",
        "GET  /count/:name",
        "POST /store/:key",
        "GET  /store/:key",
        "DELETE /store/:key",
        "GET  /store",
        "GET  /with-headers",
        "GET  /old-path",
        "GET  /slow"
    ]}
}
