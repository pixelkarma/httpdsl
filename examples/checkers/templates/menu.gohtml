<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkers</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="container">
        <h1>Checkers</h1>
        <div class="menu">
            <button id="new-game-btn" class="btn">New Game</button>
            <div class="join-form">
                <input type="text" id="room-key" maxlength="4" placeholder="Room Key" autocapitalize="characters">
                <button id="join-btn" class="btn">Join</button>
            </div>
        </div>
        <p id="error-msg" class="error"></p>
    </div>
    <script src="/static/menu.js"></script>
</body>
</html>
