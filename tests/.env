# Required by /test/builtins/env-fn assertions.
TEST_ENV_VALUE=hello-from-dotenv

# Local test toggles for remote database integration tests
# Uncomment to enable during `./tests/run.sh`

# TEST_POSTGRES=1
# TEST_MYSQL=1

# Optional connection string overrides used by tests/test_server.httpdsl
# PG_URL=postgres://postgres:testpass@localhost:5432/testdb?sslmode=disable
# MYSQL_URL=root:testpass@tcp(localhost:3306)/testdb
