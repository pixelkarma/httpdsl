// ===== Closure / HOF tests =====
group "/test/closures" {
    route GET "mutable-capture" {
        counter = 0
        inc = fn() {
            counter += 1
            return counter
        }
        a = inc()
        b = inc()
        c = inc()
        response.body = results([
            assert_eq(a, 1, "first call"),
            assert_eq(b, 2, "second call"),
            assert_eq(c, 3, "third call"),
            assert_eq(counter, 3, "captured var mutated")
        ])
    }

    route GET "fn-as-arg" {
        apply = fn(f, x) { return f(x) }
        double = fn(n) { return n * 2 }
        negate = fn(n) { return 0 - n }
        response.body = results([
            assert_eq(apply(double, 5), 10, "pass fn double"),
            assert_eq(apply(negate, 7), -7, "pass fn negate")
        ])
    }

    route GET "fn-return-fn" {
        make_adder = fn(n) {
            return fn(x) { return x + n }
        }
        add5 = make_adder(5)
        add10 = make_adder(10)
        response.body = results([
            assert_eq(add5(3), 8, "adder 5+3"),
            assert_eq(add10(3), 13, "adder 10+3")
        ])
    }

    route GET "each-closure" {
        fns = []
        each i in [10, 20, 30] {
            fns = append(fns, fn() { return i })
        }
        response.body = results([
            assert_eq(len(fns), 3, "captured 3 fns")
        ])
    }
}

