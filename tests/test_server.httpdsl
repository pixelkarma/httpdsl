    response.body = { message: "echo", method: request.method }
}

route POST "test/fetch/echo" json {
    response.body = { message: "echo", data: request.data }
} else {
    response.body = { message: "echo", data: null }
}

route GET "test/fetch/basic" {
    resp = fetch(`http://localhost:${env("TEST_PORT", "9999")}/test/fetch/echo`)
    response.body = results([
        assert_eq(resp.status, 200, "fetch status"),
        assert_eq(resp.body.message, "echo", "fetch body"),
        assert_eq(resp.body.method, "GET", "fetch method")
    ])
}

route GET "test/fetch/post" {
    resp = fetch(`http://localhost:${env("TEST_PORT", "9999")}/test/fetch/echo`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: { greeting: "hi" }
    })
    response.body = results([
        assert_eq(resp.status, 200, "fetch POST status"),
        assert_eq(resp.body.data.greeting, "hi", "fetch POST body")
    ])
}

// ===== Error handling tests =====
group "/test/errors" {
    route GET "throw-catch" {
        caught = null
        try {
            throw "custom error"
        } catch(e) {
            caught = e
        }
        response.body = results([
            assert_eq(caught, "custom error", "catch gets thrown value")
        ])
    }

    route GET "throw-object" {
        caught = null
        try {
            throw { code: 42, message: "bad thing" }
        } catch(e) {
            caught = e
        }
        response.body = results([
            assert_eq(caught.code, 42, "catch object code"),
            assert_eq(caught.message, "bad thing", "catch object message")
        ])
    }

    route GET "nested-try" {
        outer = null
        inner = null
        try {
            try {
                throw "inner error"
            } catch(e) {
                inner = e
                throw "outer error"
            }
        } catch(e) {
            outer = e
        }
        response.body = results([
            assert_eq(inner, "inner error", "inner catch"),
            assert_eq(outer, "outer error", "outer catch")
        ])
    }
}

