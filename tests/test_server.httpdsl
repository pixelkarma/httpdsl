server {
    port 9999
    cors {
        origins "*"
    }
}

// ===== Error handlers =====
error 404 {
    response.type = "json"
    response.body = {
        error: "not found",
        path: request.path,
        method: request.method
    }
}

error 500 {
    response.type = "json"
    response.body = {
        error: "internal server error",
        path: request.path
    }
}

// ===== Test helpers =====
fn assert_eq(actual, expected, name) {
    if actual == expected {
        return { pass: true, test: name }
    }
    return { pass: false, test: name, expected: expected, actual: actual }
}

fn assert_true(val, name) {
    if val {
        return { pass: true, test: name }
    }
    return { pass: false, test: name, expected: true, actual: val }
}

fn assert_false(val, name) {
    if !val {
        return { pass: true, test: name }
    }
    return { pass: false, test: name, expected: false, actual: val }
}

fn results(checks) {
    all_pass = true
    each check in checks {
        if !check.pass {
            all_pass = false
        }
    }
    return { pass: all_pass, checks: checks }
}

