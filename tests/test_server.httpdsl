// ===== SQLite tests =====
group "/test/sqlite" {
    route GET "crud" {
        mydb = db.open("sqlite", ":memory:")
        mydb.exec("CREATE TABLE users (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT, age INTEGER)")

        // Insert
        r1 = mydb.exec("INSERT INTO users (name, age) VALUES (?, ?)", ["Alice", 30])
        r2 = mydb.exec("INSERT INTO users (name, age) VALUES (?, ?)", ["Bob", 25])
        r3 = mydb.exec("INSERT INTO users (name, age) VALUES (?, ?)", ["Charlie", 35])

        // Query all
        rows = mydb.query("SELECT name, age FROM users ORDER BY name")

        // Query one
        one = mydb.query_one("SELECT name, age FROM users WHERE name = ?", ["Bob"])

        // Query value
        count = mydb.query_value("SELECT COUNT(*) FROM users")

        // Update
        mydb.exec("UPDATE users SET age = 31 WHERE name = ?", ["Alice"])
        updated = mydb.query_one("SELECT age FROM users WHERE name = ?", ["Alice"])

        // Delete
        mydb.exec("DELETE FROM users WHERE name = ?", ["Charlie"])
        after_delete = mydb.query("SELECT name FROM users ORDER BY name")

        mydb.close()

        response.body = results([
            assert_eq(r1.last_insert_id, 1, "insert first id"),
            assert_eq(r2.last_insert_id, 2, "insert second id"),
            assert_eq(r3.last_insert_id, 3, "insert third id"),
            assert_eq(len(rows), 3, "query all count"),
            assert_eq(rows[0].name, "Alice", "query first name"),
            assert_eq(rows[1].name, "Bob", "query second name"),
            assert_eq(rows[2].name, "Charlie", "query third name"),
            assert_eq(one.name, "Bob", "query_one name"),
            assert_eq(one.age, 25, "query_one age"),
            assert_eq(count, 3, "query_value count"),
            assert_eq(updated.age, 31, "update age"),
            assert_eq(len(after_delete), 2, "delete count"),
            assert_eq(after_delete[0].name, "Alice", "after delete first"),
            assert_eq(after_delete[1].name, "Bob", "after delete second")
        ])
    }

    route GET "types" {
        mydb = db.open("sqlite", ":memory:")
        mydb.exec("CREATE TABLE things (id INTEGER PRIMARY KEY, label TEXT, score REAL, active BOOLEAN)")
        mydb.exec("INSERT INTO things (label, score, active) VALUES (?, ?, ?)", ["hello", 3.14, true])
        mydb.exec("INSERT INTO things (label, score, active) VALUES (?, ?, ?)", [null, 0.0, false])

        rows = mydb.query("SELECT label, score, active FROM things ORDER BY id")
        mydb.close()

        response.body = results([
            assert_eq(rows[0].label, "hello", "string type"),
            assert_eq(rows[0].score, 3.14, "float type"),
            assert_eq(rows[1].score, 0.0, "zero float"),
            assert_eq(len(rows), 2, "row count")
        ])
    }

    route GET "empty" {
        mydb = db.open("sqlite", ":memory:")
        mydb.exec("CREATE TABLE empty_table (id INTEGER PRIMARY KEY, val TEXT)")

        rows = mydb.query("SELECT * FROM empty_table")
        one = mydb.query_one("SELECT * FROM empty_table")

        mydb.close()

        response.body = results([
            assert_eq(len(rows), 0, "empty query returns empty array"),
            assert_eq(one, null, "query_one on empty returns null")
        ])
    }
}

// ===== Untested builtins =====
group "/test/builtins" {
    route GET "type-fn" {
        response.body = results([
            assert_eq(type(42), "int", "type int"),
            assert_eq(type(3.14), "float", "type float"),
            assert_eq(type("hi"), "string", "type string"),
            assert_eq(type(true), "bool", "type bool"),
            assert_eq(type(null), "null", "type null"),
            assert_eq(type([1,2]), "array", "type array"),
            assert_eq(type({a:1}), "object", "type object")
        ])
    }

    route GET "reduce" {
        nums = [1, 2, 3, 4, 5]
        sum = reduce(nums, fn(acc, x) { return acc + x }, 0)
        product = reduce(nums, fn(acc, x) { return acc * x }, 1)
        response.body = results([
            assert_eq(sum, 15, "reduce sum"),
            assert_eq(product, 120, "reduce product")
        ])
    }

    route GET "has-keys-values" {
        obj = { name: "Alice", age: 30 }
        k = keys(obj)
        v = values(obj)
        response.body = results([
            assert_true(has(obj, "name"), "has existing key"),
            assert_false(has(obj, "email"), "has missing key"),
            assert_eq(len(k), 2, "keys count"),
            assert_eq(len(v), 2, "values count")
        ])
    }

    route GET "index-of" {
        arr = [10, 20, 30, 40]
        response.body = results([
            assert_eq(index_of(arr, 20), 1, "index_of found"),
            assert_eq(index_of(arr, 99), -1, "index_of not found"),
            assert_eq(index_of("hello world", "world"), 6, "index_of string")
        ])
    }

    route GET "starts-ends" {
        s = "hello world"
        response.body = results([
            assert_true(starts_with(s, "hello"), "starts_with true"),
            assert_false(starts_with(s, "world"), "starts_with false"),
            assert_true(ends_with(s, "world"), "ends_with true"),
            assert_false(ends_with(s, "hello"), "ends_with false")
        ])
    }

    route GET "repeat-fn" {
        response.body = results([
            assert_eq(repeat("ab", 3), "ababab", "repeat string"),
            assert_eq(repeat("x", 0), "", "repeat zero")
        ])
    }

    route GET "delete-fn" {
        obj = { a: 1, b: 2, c: 3 }
        delete(obj, "b")
        response.body = results([
            assert_false(has(obj, "b"), "delete removes key"),
            assert_eq(len(keys(obj)), 2, "delete reduces size")
        ])
    }

    route GET "json-parse-stringify" {
        encoded = json.stringify({ name: "Bob", age: 25 })
        parsed = json.parse(encoded)
        response.body = results([
            assert_eq(type(encoded), "string", "stringify returns string"),
            assert_eq(parsed.name, "Bob", "parse restores name"),
            assert_eq(parsed.age, 25, "parse restores age"),
            assert_eq(json.parse("invalid"), null, "parse invalid returns null")
        ])
    }

    route GET "date-parse" {
        ts = date_parse("2024-01-15", "2006-01-02")
        response.body = results([
            assert_true(ts > 0, "date_parse returns positive timestamp"),
            assert_eq(date_parse("bad", "2006-01-02"), null, "date_parse bad input")
        ])
    }

    route GET "env-fn" {
        // PATH should always be set
        path_val = env("PATH")
        missing = env("HTTPDSL_NONEXISTENT_VAR")
        with_default = env("HTTPDSL_NONEXISTENT_VAR", "fallback")
        response.body = results([
            assert_true(len(path_val) > 0, "env PATH exists"),
            assert_eq(missing, null, "env missing returns null"),
            assert_eq(with_default, "fallback", "env missing with default")
        ])
    }

    route GET "sleep-fn" {
        start = now_ms()
        sleep(50)
        elapsed = now_ms() - start
        response.body = results([
            assert_true(elapsed >= 40, "sleep at least 40ms")
        ])
    }

    route GET "now-fns" {
        ts = now()
        ms = now_ms()
        response.body = results([
            assert_true(ts > 1700000000, "now returns recent unix timestamp"),
            assert_true(ms > 1700000000000, "now_ms returns recent ms timestamp")
        ])
    }
}

// ===== Operator tests =====
group "/test/operators" {
    route GET "compound-assign" {
        x = 10
        x += 5
        y = 20
        y -= 8
        response.body = results([
            assert_eq(x, 15, "+= operator"),
            assert_eq(y, 12, "-= operator")
        ])
    }

    route GET "modulo" {
        response.body = results([
            assert_eq(10 % 3, 1, "modulo 10%3"),
            assert_eq(15 % 5, 0, "modulo 15%5"),
            assert_eq(7 % 2, 1, "modulo 7%2")
        ])
    }

    route GET "string-concat" {
        a = "hello"
        b = " world"
        response.body = results([
            assert_eq(a + b, "hello world", "string concat"),
            assert_eq("num: " + str(42), "num: 42", "string + int coercion")
        ])
    }

    route GET "comparisons" {
        response.body = results([
            assert_true(1 < 2, "less than"),
            assert_true(2 > 1, "greater than"),
            assert_true(2 <= 2, "less than or equal"),
            assert_true(3 >= 3, "greater than or equal"),
            assert_true(1 != 2, "not equal"),
            assert_true("a" < "b", "string less than")
        ])
    }

    route GET "logical" {
        response.body = results([
            assert_true(true && true, "and true"),
            assert_false(true && false, "and false"),
            assert_true(true || false, "or true"),
            assert_false(false || false, "or false"),
            assert_true(!false, "not false"),
            assert_false(!true, "not true")
        ])
    }
}

